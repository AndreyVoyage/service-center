# docker/.env.example
# Пример переменных окружения для production
# Скопируйте в .env и заполните реальными значениями

# ==========================================
# КЛИЕНТ
# ==========================================
CLIENT_NAME=client1
VERSION=latest

# ==========================================
# ДОМЕНЫ И URL
# ==========================================
DOMAIN=example.com
CMS_URL=https://admin.example.com
WEB_URL=https://example.com

# ==========================================
# БАЗА ДАННЫХ
# ==========================================
DB_USER=payload
DB_PASSWORD=your_secure_password_here
DB_NAME=payload_cms

# ==========================================
# PAYLOAD CMS
# ==========================================
PAYLOAD_SECRET=your-secret-key-min-32-characters-long

# ==========================================
# TELEGRAM УВЕДОМЛЕНИЯ (опционально)
# ==========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==========================================
# REVALIDATE TOKEN (для ISR)
# ==========================================
REVALIDATE_TOKEN=your-revalidate-token

# ==========================================
# ПОРТЫ (для локальной разработки)
# ==========================================
HTTP_PORT=80
HTTPS_PORT=443

# ==========================================
# GITHUB (для CI/CD)
# ==========================================
GITHUB_OWNER=your-github-username
GITHUB_TOKEN=ghp_your_token_here
